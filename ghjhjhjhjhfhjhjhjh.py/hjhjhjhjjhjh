def bubble_sort(A):
    n = len(A)
    
    for i in range(n - 1):
        swapped = False  
        for j in range(n - 1 - i):
            if A[j] > A[j + 1]:
                A[j], A[j + 1] = A[j + 1], A[j]
                swapped = True
     
        if not swapped:
            break
    return A


data = [64, 34, 25, 12, 22, 11, 90]
sorted_data = bubble_sort(data)
print("Отсортированный массив:", sorted_data)

